@RestController
@RequestMapping("/api/accounts")
public class AccountController {

    // GET /api/accounts/all
    @GetMapping("/all")
    public List<Account> getAllAccounts() {
        return accountService.findAll();
    }

    // GET /api/accounts/ACC001
    @GetMapping("/{accountNumber}")           // ← @PathVariable usage here
    public Account getAccount(@PathVariable String accountNumber) {
        return accountService.findByAccountNumber(accountNumber);
    }

    // POST /api/accounts/create
    @PostMapping("/create")
    public Account createAccount(@RequestBody Account account) {  // ← @RequestBody
        return accountService.createAccount(account);
    }

    // PUT /api/accounts/ACC001/deposit?amount=5000
    @PutMapping("/{accountNumber}/deposit")
    public Account deposit(
        @PathVariable String accountNumber,           // ← from URL path
        @RequestParam Double amount                   // ← from ?amount=5000
    ) {
        return accountService.deposit(accountNumber, amount);
    }

    // DELETE /api/accounts/ACC001
    @DeleteMapping("/{accountNumber}")
    public String deleteAccount(@PathVariable String accountNumber) {
        accountService.delete(accountNumber);
        return "Account " + accountNumber + " closed.";
    }
}





// This is the DTO for a transfer request
public class TransferRequest {
    private String fromAccount;
    private String toAccount;
    private Double amount;
    // getters, setters
}
// In Controller
@PostMapping("/transfer")
public String transfer(@RequestBody TransferRequest request) {
    // Spring automatically converts incoming JSON → TransferRequest object
    accountService.transfer(
        request.getFromAccount(),
        request.getToAccount(),
        request.getAmount()
    );
    return "Transfer successful";
}








@Service   // ← Tells Spring: manage this as a bean + signals "this is business logic"
public class AccountService {

    private final AccountRepository accountRepository;

    public AccountService(AccountRepository accountRepository) {
        this.accountRepository = accountRepository;
    }

    public Account deposit(String accountNumber, Double amount) {
        Account account = accountRepository.findByAccountNumber(accountNumber)
            .orElseThrow(() -> new RuntimeException("Account not found"));

        if (amount <= 0) {
            throw new IllegalArgumentException("Deposit amount must be positive");
        }

        account.setBalance(account.getBalance() + amount);
        return accountRepository.save(account);
    }

    public void transfer(String from, String to, Double amount) {
        // Business rule: no negative transfers, check balance, etc.
        Account sender = accountRepository.findByAccountNumber(from)
            .orElseThrow(() -> new RuntimeException("Sender not found"));

        if (sender.getBalance() < amount) {
            throw new RuntimeException("Insufficient funds");
        }

        Account receiver = accountRepository.findByAccountNumber(to)
            .orElseThrow(() -> new RuntimeException("Receiver not found"));

        sender.setBalance(sender.getBalance() - amount);
        receiver.setBalance(receiver.getBalance() + amount);

        accountRepository.save(sender);
        accountRepository.save(receiver);
    }
}