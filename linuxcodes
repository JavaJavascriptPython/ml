#!/bin/bash

input_file="input.txt"
output_file="ports.txt"

port=""
has_established=0

> "$output_file"   # clear output file

while IFS= read -r line
do
    if [[ $line == Port:* ]]; then
        # Before switching, check previous port
        if [[ -n $port && $has_established -eq 0 ]]; then
            echo "$port" >> "$output_file"
        fi

        # Extract new port
        port=$(echo "$line" | cut -d':' -f2)
        has_established=0

    elif [[ $line == *ESTABLISHED* ]]; then
        has_established=1
    fi

done < "$input_file"

# Check last block
if [[ -n $port && $has_established -eq 0 ]]; then
    echo "$port" >> "$output_file"
fi

echo "Filtered ports saved in $output_file"


# ✅ While loop on output file
while read port
do
    echo "Processing Port: $port"
    
    # Your logic here
    # Example:
    # grep "$port" /fns/I/sysout/*

done < "$output_file"